# --- LLM ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers
# Authorization callback URL must be: http://localhost:8000/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub Webhook ---
# A random string of your choosing; set the same value when configuring
# the webhook in your repo settings (Content type: application/json).
GITHUB_WEBHOOK_SECRET=

# --- Database ---
# Use a free PostgreSQL instance from https://neon.tech.
# Copy the connection string from the Neon dashboard and paste it here.
# It must include ?sslmode=require because Neon only accepts TLS connections.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# --- App secrets ---
JWT_SECRET=change_me_to_a_long_random_string
FRONTEND_URL=http://localhost:3000
